# API URL for the backend (used by client-side API calls via proxy)
NEXT_PUBLIC_API_URL="http://localhost:3030/api/proxy"

# Direct backend URL (used by server-side proxy route handler)
NEST_API_URL="http://localhost:8080"

# Frontend URL (used for redirect validation)
NEXT_PUBLIC_FRONTEND_URL="http://localhost:3030"

# Google OAuth Client ID (create at https://console.cloud.google.com/apis/credentials)
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id-here"
